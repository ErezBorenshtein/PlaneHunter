<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#050A12"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="14dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <View
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_drag_handle" />

    <TextView
        android:id="@+id/textChooserTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Plane"
        android:textColor="#EAF6FF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textChooserSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Several planes are close to your tap"
        android:textColor="#88AFC9"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPlanes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:nestedScrollingEnabled="false" />

</LinearLayout>