<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/textTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Alert Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/textSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Choose which aircraft categories will trigger notifications."
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/textTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Master switch -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchAlertsEnabled"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Enable aircraft alerts"
            app:layout_constraintTop_toBottomOf="@id/textSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Quick actions -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSelectAll"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            android:text="Select all"
            app:layout_constraintTop_toBottomOf="@id/switchAlertsEnabled"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/buttonClearAll"
            app:layout_constraintHorizontal_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonClearAll"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="8dp"
            android:text="Clear all"
            app:layout_constraintTop_toBottomOf="@id/switchAlertsEnabled"
            app:layout_constraintStart_toEndOf="@id/buttonSelectAll"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1" />

        <!-- Categories header -->
        <TextView
            android:id="@+id/textCategoriesHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Aircraft categories"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/buttonSelectAll"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 1 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="1 - No ADS-B Emitter Category Information"
            app:layout_constraintTop_toBottomOf="@id/textCategoriesHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 2 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="2 - Light (&lt; 15500 lbs)"
            app:layout_constraintTop_toBottomOf="@id/checkCategory1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 3 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="3 - Small (15500 to 75000 lbs)"
            app:layout_constraintTop_toBottomOf="@id/checkCategory2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 4 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="4 - Large (75000 to 300000 lbs)"
            app:layout_constraintTop_toBottomOf="@id/checkCategory3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 5 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="5 - High Vortex Large (e.g. B-757)"
            app:layout_constraintTop_toBottomOf="@id/checkCategory4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 6 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="6 - Heavy (&gt; 300000 lbs)"
            app:layout_constraintTop_toBottomOf="@id/checkCategory5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 7 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory7"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="7 - High Performance (&gt; 5g acceleration and 400 kts)"
            app:layout_constraintTop_toBottomOf="@id/checkCategory6"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 8 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory8"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="8 - Rotorcraft"
            app:layout_constraintTop_toBottomOf="@id/checkCategory7"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 9 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory9"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="9 - Glider / sailplane"
            app:layout_constraintTop_toBottomOf="@id/checkCategory8"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 10 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="10 - Lighter-than-air"
            app:layout_constraintTop_toBottomOf="@id/checkCategory9"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 11 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory11"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="11 - Parachutist / Skydiver"
            app:layout_constraintTop_toBottomOf="@id/checkCategory10"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 12 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory12"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="12 - Ultralight / hang-glider / paraglider"
            app:layout_constraintTop_toBottomOf="@id/checkCategory11"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 13 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory13"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="13 - Reserved"
            app:layout_constraintTop_toBottomOf="@id/checkCategory12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 14 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory14"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="14 - Unmanned Aerial Vehicle"
            app:layout_constraintTop_toBottomOf="@id/checkCategory13"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 15 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory15"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="15 - Space / Trans-atmospheric vehicle"
            app:layout_constraintTop_toBottomOf="@id/checkCategory14"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 16 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory16"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="16 - Surface Vehicle - Emergency Vehicle"
            app:layout_constraintTop_toBottomOf="@id/checkCategory15"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 17 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory17"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="17 - Surface Vehicle - Service Vehicle"
            app:layout_constraintTop_toBottomOf="@id/checkCategory16"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 18 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory18"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="18 - Point Obstacle (includes tethered balloons)"
            app:layout_constraintTop_toBottomOf="@id/checkCategory17"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 19 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory19"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="19 - Cluster Obstacle"
            app:layout_constraintTop_toBottomOf="@id/checkCategory18"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 20 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory20"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="20 - Line Obstacle"
            app:layout_constraintTop_toBottomOf="@id/checkCategory19"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:text="Save"
            app:layout_constraintTop_toBottomOf="@id/checkCategory20"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>