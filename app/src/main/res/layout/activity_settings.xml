<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/textTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Alert Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/textSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Choose which aircraft categories will trigger notifications."
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/textTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />



        <!-- Quick actions -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSelectAll"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            android:text="Select all"
            app:layout_constraintTop_toBottomOf="@id/textSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/buttonClearAll"
            app:layout_constraintHorizontal_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonClearAll"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="8dp"
            android:text="Clear all"
            app:layout_constraintTop_toBottomOf="@id/textSubtitle"
            app:layout_constraintStart_toEndOf="@id/buttonSelectAll"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1" />

        <!-- Categories header -->
        <TextView
            android:id="@+id/textCategoriesHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Aircraft categories"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/buttonSelectAll"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 1 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Airliner"
            app:layout_constraintTop_toBottomOf="@id/textCategoriesHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 2 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Cargo"
            app:layout_constraintTop_toBottomOf="@id/checkCategory1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 3 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Buisiness Jet"
            app:layout_constraintTop_toBottomOf="@id/checkCategory2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 4 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="General Aviation"
            app:layout_constraintTop_toBottomOf="@id/checkCategory3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 5 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="TurboProp Regional"
            app:layout_constraintTop_toBottomOf="@id/checkCategory4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 6 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Helicopter"
            app:layout_constraintTop_toBottomOf="@id/checkCategory5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category 7 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkCategory7"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Military / Government"
            app:layout_constraintTop_toBottomOf="@id/checkCategory6"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:text="Save"
            app:layout_constraintTop_toBottomOf="@id/checkCategory7"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>