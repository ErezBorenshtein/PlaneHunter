<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="18dp"
    android:paddingTop="12dp"
    android:paddingEnd="18dp"
    android:paddingBottom="22dp"
    android:background="#1E1F24">

    <!-- Drag Handle -->
    <View
        android:id="@+id/dragHandle"
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:background="#555"
        android:alpha="0.6"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Plane Image -->
    <ImageView
        android:id="@+id/imgPlane"
        android:layout_width="0dp"
        android:layout_height="210dp"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        android:scaleType="fitCenter"
        android:src="@drawable/plane_placeholder"
        android:background="@drawable/bg_plane_dark"
        app:layout_constraintTop_toBottomOf="@id/dragHandle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progPlane"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/imgPlane"
        app:layout_constraintBottom_toBottomOf="@id/imgPlane"
        app:layout_constraintStart_toStartOf="@id/imgPlane"
        app:layout_constraintEnd_toEndOf="@id/imgPlane" />

    <!-- Flag -->
    <ImageView
        android:id="@+id/imgFlag"
        android:layout_width="36dp"
        android:layout_height="24dp"
        android:layout_marginTop="18dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_flag_dark"
        app:layout_constraintTop_toBottomOf="@id/imgPlane"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Registration -->
    <TextView
        android:id="@+id/tvRegistration"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Registration: Loading..."
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginStart="10dp"
        app:layout_constraintTop_toTopOf="@id/imgFlag"
        app:layout_constraintBottom_toBottomOf="@id/imgFlag"
        app:layout_constraintStart_toEndOf="@id/imgFlag"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Type -->
    <TextView
        android:id="@+id/tvTypeName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Aircraft: Loading..."
        android:textSize="15sp"
        android:textColor="#B0B6C3"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/imgFlag"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Altitude -->
    <TextView
        android:id="@+id/tvAltitude"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Altitude:"
        android:textSize="15sp"
        android:textColor="#B0B6C3"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvTypeName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Heading -->
    <TextView
        android:id="@+id/tvHeading"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Heading:"
        android:textSize="15sp"
        android:textColor="#B0B6C3"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvAltitude"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Capture -->
    <Button
        android:id="@+id/btnCapture"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Capture"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4D6BFF"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/tvHeading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>